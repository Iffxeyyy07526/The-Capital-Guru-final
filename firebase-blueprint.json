{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of The Capital Guru",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "mobileNumber": {
          "type": "string",
          "description": "Mobile phone number"
        },
        "telegramUsername": {
          "type": "string",
          "description": "Telegram username for channel access"
        },
        "address": {
          "type": "string",
          "description": "Physical address"
        },
        "subscriptionPlan": {
          "type": "string",
          "description": "ID of the active subscription plan (e.g., 'monthly', 'yearly')"
        },
        "subscriptionStatus": {
          "type": "string",
          "enum": ["active", "inactive", "canceled"],
          "description": "Current status of the subscription"
        },
        "subscriptionExpiry": {
          "type": "string",
          "format": "date-time",
          "description": "ISO string of when the subscription expires"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO string of account creation date"
        }
      },
      "required": ["uid", "name", "email", "mobileNumber", "telegramUsername", "address", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and subscription details"
    }
  }
}
